# ── LLM Provider ──────────────────────────
# Uncomment and set the API key for your provider
# OPENROUTER_API_KEY=sk-or-v1-xxx
# ZHIPU_API_KEY=xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# GEMINI_API_KEY=xxx

# ── Local LLM (llama.cpp) ────────────────
# PICOCLAW_PROVIDERS_LLAMACPP_ENABLED=true
# PICOCLAW_PROVIDERS_LLAMACPP_MODE=server        # "server" or "binary"
# PICOCLAW_PROVIDERS_LLAMACPP_API_BASE=http://localhost:8080/v1  # server mode
# PICOCLAW_PROVIDERS_LLAMACPP_BINARY_PATH=/usr/local/bin/llama-cli  # binary mode
# PICOCLAW_PROVIDERS_LLAMACPP_MODEL_PATH=/home/diego/models/qwen2.5-1.5b-instruct-q4_k_m.gguf
# PICOCLAW_PROVIDERS_LLAMACPP_CONTEXT_SIZE=2048
# PICOCLAW_PROVIDERS_LLAMACPP_THREADS=4
# PICOCLAW_PROVIDERS_LLAMACPP_MAX_TOKENS=512
# PICOCLAW_PROVIDERS_LLAMACPP_FALLBACK=true       # fallback when cloud is down

# ── Chat Channel ──────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC...
# DISCORD_BOT_TOKEN=xxx
# LINE_CHANNEL_SECRET=xxx
# LINE_CHANNEL_ACCESS_TOKEN=xxx

# ── Web Search (optional) ────────────────
# BRAVE_SEARCH_API_KEY=BSA...

# ── Timezone ──────────────────────────────
TZ=Asia/Tokyo
